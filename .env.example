# =============================================================================
# DMG Movie Ticket Booking System - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -- PostgreSQL Database --
DB_URL=jdbc:postgresql://localhost:5432/movie-ticket-booking
DB_USERNAME=postgres
DB_PASSWORD=password

# -- JWT Authentication --
JWT_SECRET=dmg-movie-booking-secret-key-must-be-at-least-256-bits-long-for-hs256-algorithm
JWT_EXPIRATION_MS=86400000

# -- Rate Limiting (Sliding Window) --
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=1

# -- Server --
SERVER_PORT=8080
