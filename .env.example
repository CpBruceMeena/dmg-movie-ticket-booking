# =============================================================================
# DMG Movie Ticket Booking System - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Then source it: export $(grep -v '^#' .env | xargs)
# =============================================================================

# -- PostgreSQL Database --
DB_URL=jdbc:postgresql://localhost:5432/movie-ticket-booking
DB_USERNAME=postgres
DB_PASSWORD=postgres

# -- RSA JWT Keys --
# Generate a 2048-bit RSA private key and extract the public key:
#   openssl genpkey -algorithm RSA -out keys/private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl pkey -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_EXPIRATION_MS=86400000

# -- Redis (for distributed seat hold management) --
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -- Rate Limiting (Sliding Window) --
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=1

# -- Server --
SERVER_PORT=8080
